meta {
  name: Login as bob and save token to env
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/account/login
  body: json
  auth: inherit
}

body:json {
  {
    "email": "calamardo@test.com",
    "password": "Pa$$w0rd"
  }
}

script:post-response {
  const user = res.getBody();
  
  test("Has properties", function () {
      expect(user).to.have.property('accessToken');
  });
  
  if (test("Has properties")) {
      bru.setGlobalEnvVar('otherToken', user.accessToken);
  }
}

settings {
  encodeUrl: true
}
